# Redstone managed (regenerated on redstone upgrade)
.redstone/

# Minecraft runtime
minecraft/run/
minecraft/build/
minecraft/.gradle/
minecraft/mc-sources/

# Created by https://www.toptal.com/developers/gitignore/api/dart,java,linux,macos,gradle,windows
